########################################
# Core client configuration (.env.local)
########################################

##############################
# API authentication (optional)
##############################

# When set, write APIs (attendance-event, unknown-faces, assign) require X-API-Key header.
# Set ATTENDANCE_API_KEY for server/Python; set both to same value for dashboard.
#ATTENDANCE_API_KEY=
#NEXT_PUBLIC_ATTENDANCE_API_KEY=

##############################
# Demo / simulator settings  #
##############################

# Phone number used by dashboard "Simulate Attendance" and other demo flows.
# Use an E.164 number (e.g. 919876543210) or a bare 10‑digit India number.
NEXT_PUBLIC_DEMO_PHONE=

##############################
# Camera stream              #
##############################

# URL of the Python MJPEG stream server (attendance_poc.py).
# For a single Windows PC deployment, leave this unset so it defaults to http://localhost:5000.
#CAMERA_STREAM_URL=http://localhost:5000

##############################
# Supabase (optional)        #
##############################

# Only required if you re‑enable Supabase auth; dashboard can run without it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

##############################
# WhatsApp providers         #
##############################

# Choose ONE provider (Twilio sandbox OR Meta WhatsApp Cloud API).

## Option 1: Twilio WhatsApp Sandbox (no Meta approval)
## 1. Sign up at https://twilio.com
## 2. Go to "Try WhatsApp" → Sandbox
## 3. Send "join <word>" from Twilio console to +1 415 523 8886
## 4. Copy Account SID & Auth Token below; set NEXT_PUBLIC_TWILIO_SANDBOX_JOIN_PHRASE for Demo Setup UI
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Join phrase (e.g. positive-express) — shown in Demo Setup so clients know what to send
NEXT_PUBLIC_TWILIO_SANDBOX_JOIN_PHRASE=
# Optional: override default sandbox from number
#TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

## Option 2: Meta WhatsApp Cloud API
## Get these from https://developers.facebook.com → App → WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional: Meta template for custom messages (body with {{1}})
# If unset, the Meta sender uses hello_world.
#WHATSAPP_MESSAGE_TEMPLATE=attendance_notification
